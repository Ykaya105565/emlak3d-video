# ============================================================
# Emlak 3D Video Platformu — Ortam Değişkenleri
# Kopyala: cp .env.example .env  (asla .env dosyasını commit etme)
# ============================================================

# --- Veritabanı ---
DATABASE_URL=postgresql+asyncpg://emlak:emlak_pass@db:5432/emlakdb
POSTGRES_USER=emlak
POSTGRES_PASSWORD=emlak_pass
POSTGRES_DB=emlakdb

# --- Redis (Celery kuyruğu) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- MinIO (S3 uyumlu depo) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_GML=gml-files
MINIO_BUCKET_PHOTOS=property-photos
MINIO_BUCKET_VIDEOS=rendered-videos

# --- Google APIs ---
# Google Geocoding API + 3D Tiles (Maps Platform)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
# Google Cloud TTS (opsiyonel; ElevenLabs kullanılıyorsa boş bırak)
GOOGLE_TTS_API_KEY=YOUR_GOOGLE_TTS_API_KEY_HERE
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-service-account.json

# --- Claude API (Anthropic) — Senaryo üretimi ---
CLAUDE_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6

# --- TTS Sağlayıcısı ---
# "google" veya "elevenlabs"
TTS_PROVIDER=google
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE
ELEVENLABS_VOICE_ID=YOUR_VOICE_ID_HERE

# --- JWT Auth ---
JWT_SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Uygulama ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Render Worker ---
RENDER_WORKER_URL=http://render-worker:8001
RENDER_WORKER_CONCURRENCY=2
RENDER_OUTPUT_DIR=/tmp/renders
FFMPEG_PATH=/usr/bin/ffmpeg

# --- Cesium Ion (opsiyonel; Google 3D Tiles tercih edilir) ---
CESIUM_ION_TOKEN=YOUR_CESIUM_ION_TOKEN_HERE

# --- Maliyet / Alarm ---
MAX_COST_PER_VIDEO_USD=5.0
COST_ALERT_EMAIL=admin@example.com
